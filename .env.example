# 环境配置文件示例
# 使用方式：复制此文件为 .env，然后填入你的真实配置

# OpenAI API Key - 从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=your_openai_api_key_here

# Midjourney API Key (第三方中转服务)
MIDJOURNEY_API_KEY=your_midjourney_api_key_here

# 代理地址（国内访问 OpenAI 需要代理，例如：api.openai.com）
# 如果能直接访问，留空即可
PROXY_HOST=

# 服务端口（默认 3000）
PORT=3000